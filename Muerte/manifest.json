{
  "manifest_version": 2,
  "version": "1.0",
  "name": "La Muerte y el Diseñador SVG",
  "description": "Un tema premium y moderno con animación SVG del diseñador contra la muerte en la barra de Firefox.",
  "author": "Hector Daniel Ayarachi Fuentes",
  "browser_specific_settings": {
    "gecko": {
      "id": "muerte-disenador-v1@hector.ayarachi"
    }
  },
  "theme": {
    "images": {
      "theme_frame": "muerte.svg"
    },
    "colors": {
      "frame": "#000000",
      "tab_background_text": "#a1a1a6",
      "toolbar": "transparent",
      "bookmark_text": "#e5e5ea",
      "toolbar_field": "rgba(255, 255, 255, 0.1)",
      "toolbar_field_text": "#ffffff",
      "toolbar_field_border": "rgba(190, 0, 42, 0.2)",
      "toolbar_field_focus": "rgba(0, 0, 0, 0.7)",
      "toolbar_field_text_focus": "#ffffff",
      "toolbar_field_border_focus": "#be002a",
      "tab_line": "#be002a",
      "tab_selected": "transparent",
      "tab_text": "#ffffff",
      "tab_background_separator": "rgba(190, 0, 42, 0.3)",
      "toolbar_top_separator": "transparent",
      "toolbar_bottom_separator": "rgba(190, 0, 42, 0.4)",
      "popup": "#0a0002",
      "popup_text": "#e5e5ea",
      "popup_border": "rgba(190, 0, 42, 0.5)",
      "ntp_background": "#000000",
      "ntp_text": "#e5e5ea"
    }
  }
}
